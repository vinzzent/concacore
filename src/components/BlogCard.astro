---
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);

const { title, description, published } = post.data;
const slug = post.id.split('/').pop();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<article class="border border-slate-200 bg-white rounded-lg p-6 flex flex-col h-full shadow-sm hover:shadow-md transition-shadow">
  <span class="text-xs font-bold text-brand-cyan mb-2 uppercase tracking-wide">{t('article') || 'Article'}</span>
  
  <h3 class="text-xl font-bold text-brand-navy mb-2 leading-tight">
    <a href={`${base}${lang}/blog/${slug}/`} class="hover:text-brand-cyan transition-colors">
      {title}
    </a>
  </h3>
  
  {description && <p class="text-brand-muted mb-4 grow text-sm leading-relaxed">{description}</p>}
  
  <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center text-sm">
    <time datetime={published.toISOString()} class="text-brand-subtle font-mono text-xs">
      {published.toLocaleDateString(lang, { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    <a href={`${base}${lang}/blog/${slug}/`} class="font-semibold text-brand-cyan hover:text-brand-cyan-dark flex items-center gap-1 transition-colors">
      {t('viewBtn') || 'View'} &rarr;
    </a>
  </div>
</article>