---
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, published } = post.data;
---

<article class="border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
  <div class="grow">
    <time datetime={published.toISOString()} class="text-sm text-gray-500 mb-2 block">
      {published.toLocaleDateString(lang, { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    <h3 class="text-xl font-bold mb-2">
      <a href={`/${lang}/blog/${post.slug}/`} class="text-blue-600 hover:text-blue-800">
        {title}
      </a>
    </h3>
    {description && <p class="text-gray-600 mb-4">{description}</p>}
  </div>
  
  <div class="mt-auto pt-4 border-t">
    <a href={`/${lang}/blog/${post.slug}/`} class="text-sm font-medium text-blue-600 hover:underline inline-flex items-center">
      {t('readMore')} <span class="ml-1">&rarr;</span>
    </a>
  </div>
</article>