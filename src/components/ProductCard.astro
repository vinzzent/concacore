---
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
import { Image } from 'astro:assets';

export interface Props {
  product: CollectionEntry<'products'>;
  lang: Locale;
}

const { product, lang } = Astro.props;
const t = useTranslations(lang);

const { title, description, isNew, image, icon } = product.data;
const slug = product.id.split('/').pop();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<article class="border border-slate-200 bg-white rounded-lg p-6 flex flex-col h-full shadow-sm hover:shadow-md transition-shadow">
  <div class="flex justify-between items-start mb-4">
    <span class="text-xs font-bold text-brand-cyan uppercase tracking-wide">
      {t('product') || 'Product'}
    </span>
    {isNew && (
      <span class="bg-brand-cyan-pale text-brand-cyan-dark text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
        {t('new') || 'NEW'}
      </span>
    )}
  </div>

  {image && (
    <a href={`${base}${lang}/products/${slug}/`} class="block mb-4 overflow-hidden rounded-md border border-slate-100">
      <Image 
        src={image} 
        alt={title} 
        class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500"
      />
    </a>
  )}

  <h3 class="text-xl font-bold text-brand-navy mb-2 leading-tight">
    <a href={`${base}${lang}/products/${slug}/`} class="hover:text-brand-cyan transition-colors flex items-center gap-2">
      {icon && (
        <Image 
          src={icon} 
          alt={`${title} icon`} 
          class="w-6 h-6 object-contain" 
        />
      )}
      {title}
    </a>
  </h3>
  
  {description && <p class="text-brand-muted mb-4 grow text-sm leading-relaxed">{description}</p>}
  
  <div class="mt-auto pt-4 border-t border-slate-100 flex justify-end items-center text-sm">
    <a href={`${base}${lang}/products/${slug}/`} class="font-semibold text-brand-cyan hover:text-brand-cyan-dark flex items-center gap-1 transition-colors">
      {t('viewBtn')} &rarr;
    </a>
  </div>
</article>