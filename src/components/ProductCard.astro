---
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  product: CollectionEntry<'products'>;
  lang: Locale;
}

const { product, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, isNew } = product.data;
const slug = product.id.split('/').pop();
---

<article class="border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xl font-bold">
      <a href={`/${lang}/products/${slug}/`} class="text-blue-600 hover:text-blue-800">
        {title}
      </a>
    </h3>
    {isNew && (
      <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">
        {t('new')}
      </span>
    )}
  </div>
  {description && <p class="text-gray-600">{description}</p>}
  <div class="mt-4">
    <a href={`/${lang}/products/${slug}/`} class="text-sm font-medium text-blue-600 hover:underline">
      {t('viewBtn')} &rarr;
    </a>
  </div>
</article>