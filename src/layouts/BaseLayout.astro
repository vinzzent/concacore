---
import "../styles/tailwind.css";
import { useTranslations } from "../i18n/translations";
import type { Locale } from "../i18n/translations";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description?: string;
  lang: Locale;
}

const { title, description, lang } = Astro.props;
const t = useTranslations(lang);

// Fetching all products for the current language
const products: CollectionEntry<"products">[] = await getCollection(
  "products",
  (entry: CollectionEntry<"products">) =>
    entry.data.lang.toLowerCase() === lang,
);

// Safe Base URL calculation
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

// Language Switcher URL Generation
const currentPath = Astro.url.pathname;

// Astro guarantees this ends with a '/'
const enUrl = currentPath.replace(new RegExp(`^${base}(en-us|pt-br)`), `${base}en-us`);
const ptUrl = currentPath.replace(new RegExp(`^${base}(en-us|pt-br)`), `${base}pt-br`);

// Check if we are in production build to avoid Pagefind 404s in dev mode
const isProd = import.meta.env.PROD;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" type="image/svg+xml" href={`${base}assets/favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />   
    {isProd && <link href={`${base}pagefind/pagefind-component-ui.css`} rel="stylesheet" />}
  </head>

  <body class="bg-brand-bg text-brand-text antialiased flex flex-col min-h-screen">
    <header class="border-b border-slate-200 py-4 bg-white shadow-sm z-50">
      <nav class="container mx-auto flex flex-wrap items-center px-4" x-data="{ open: false, mobileOpen: false }">
        <a
          href={`${base}${lang}/`}
          class="shrink-0 mr-6 transition-transform hover:scale-105"
        >
          <img src={`${base}assets/logo.svg`} alt="Concacore Logo" class="h-12 w-auto" />
        </a>

        <button
          class="md:hidden ml-auto flex items-center text-brand-navy focus:outline-none p-1"
          @click="mobileOpen = !mobileOpen"
          :aria-expanded="mobileOpen"
          aria-controls="main-menu"
          aria-label="Toggle navigation menu"
        >
          <Icon name="heroicons:bars-3" class="w-6 h-6" x-show="!mobileOpen" />
          <Icon name="heroicons:x-mark" class="w-6 h-6" x-show="mobileOpen" style="display: none;" />
        </button>

        <div
          id="main-menu"
          class="w-full md:w-auto md:flex md:items-center md:gap-6 md:grow mt-4 md:mt-0 order-last md:order-0"
          :class="mobileOpen ? 'flex flex-col gap-4' : 'hidden'"
        >
          <a href={`${base}${lang}/`} class="nav-link font-bold block">{t("home") || "Home"}</a>

          <div class="relative" @keydown.escape="open = false">
            <button
              @click="open = !open"
              class="nav-link flex items-center justify-between w-full md:w-auto gap-1 cursor-pointer"
              :aria-expanded="open"
              aria-controls="products-menu"
            >
              {t("products") || "Products"}
              <Icon
                name="heroicons:chevron-down"
                class="w-4 h-4 transition-transform"
                :class="open ? 'rotate-180' : ''"
              />
            </button>

            <div
              id="products-menu"
              x-show="open"
              @click.away="open = false"
              x-transition.opacity.duration.150ms
              class="md:absolute top-full left-0 md:w-56 md:bg-white md:border md:border-slate-200 md:rounded-md md:shadow-lg py-2 mt-2 md:mt-1 border-l-2 md:border-l-0 border-brand-cyan/30 pl-2 md:pl-0"
              style="display: none;"
            >
              {
                products.map((product) => {
                  const slug = product.id.split("/").pop();
                  return (
                    <a
                      href={`${base}${lang}/products/${slug}/`}
                      @click="open = false; mobileOpen = false"
                      class="block px-4 py-2 text-sm text-brand-text hover:bg-brand-surface hover:text-brand-cyan transition-colors"
                    >
                      {product.data.title}
                    </a>
                  );
                })
              }
            </div>
          </div>

          <a href={`${base}${lang}/blog/`} class="nav-link block">{t("blog") || "Blog"}</a>
          <a href={`${base}${lang}/solutions/`} class="nav-link block">{t("solutions") || "Solutions"}</a>

          <div class="md:ml-auto flex flex-col md:flex-row md:items-center gap-4 md:gap-2 mt-2 md:mt-0 pt-4 md:pt-0 border-t md:border-none border-slate-200">
            <div class="relative min-w-50">
              <pagefind-searchbox></pagefind-searchbox>
            </div>

            <div class="flex items-center gap-2 md:border-l border-slate-300 md:pl-4">
              <a
                href={enUrl}
                class={`text-sm font-bold transition-opacity hover:text-brand-cyan ${lang === "en-us" ? "text-brand-cyan" : "text-slate-400 hover:opacity-100"}`}
              >
                EN
              </a>
              <span class="text-slate-300 text-sm">|</span>
              <a
                href={ptUrl}
                class={`text-sm font-bold transition-opacity hover:text-brand-cyan ${lang === "pt-br" ? "text-brand-cyan" : "text-slate-400 hover:opacity-100"}`}
              >
                PT
              </a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main data-pagefind-body class="container mx-auto py-8 px-4 grow">
      <slot />
    </main>

    <footer class="border-t border-slate-200 py-12 mt-12 bg-white">
      <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <img src={`${base}assets/logo.svg`} alt="Concacore Logo" class="h-8 w-auto mb-4" />
          <p class="text-sm text-brand-muted">
            {t("footerTagline") || "Turning data into action."}
          </p>
        </div>
        <div>
          <h4 class="font-bold text-brand-navy mb-4">
            {t("products") || "Products"}
          </h4>
          <ul class="space-y-2">
            {
              products.map((p) => {
                const slug = p.id.split("/").pop();
                return (
                  <li>
                    <a
                      href={`${base}${lang}/products/${slug}/`}
                      class="text-sm text-brand-muted hover:text-brand-cyan transition-colors"
                    >
                      {p.data.title}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-brand-navy mb-4">{t("company")}</h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={`${base}${lang}/`}
                class="text-brand-muted hover:text-brand-cyan transition-colors"
                >{t("home") || "Home"}</a>
            </li>
            <li>
              <a
                href={`${base}${lang}/blog/`}
                class="text-brand-muted hover:text-brand-cyan transition-colors"
                >{t("blog") || "Blog"}</a>
            </li>
            <li>
              <a
                href={`${base}${lang}/solutions/`}
                class="text-brand-muted hover:text-brand-cyan transition-colors"
                >{t("solutions") || "Solutions"}</a>
            </li>
          </ul>
        </div>
      </div>

      <div
        class="container mx-auto px-4 border-t border-slate-100 pt-8 mt-8 text-center text-sm text-brand-muted"
      >
        <p>
          &copy;
          {new Date().getFullYear()} • {
            t("rights") || "All rights reserved"
          } • {t("builtWith") || "Built with Astro"
          } • {t("searchPoweredBy") || "Search powered by Pagefind"}
        </p>
      </div>
    </footer>

    {isProd && <script is:inline src={`${base}pagefind/pagefind-component-ui.js`} />}
  </body>
</html>