---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
import { Icon } from 'astro-icon/components'; // <-- Imported Astro Icon

export interface Props {
  product: CollectionEntry<'products'>;
  lang: Locale;
}

const { product, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, appsource, icon, image, repo, email } = product.data;

// Extract slug to match with related posts tags
const slug = product.id.split('/').pop() || '';

// Fetch related blog posts dynamically
const allPosts = await getCollection('blog', (entry) => entry.data.lang.toLowerCase() === lang);
const relatedPosts = allPosts.filter(post => post.data.tags?.includes(slug));
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <div class="border-b border-slate-200 pb-8 mb-8">
      <div class="flex items-center gap-4 mb-4">
        {icon && <Image src={icon} alt={`${title} icon`} class="w-16 h-16 object-contain" />}
        <h1 class="text-4xl font-extrabold text-brand-navy">{title}</h1>
      </div>
      
      {description && <p class="text-xl text-brand-muted leading-relaxed mb-6">{description}</p>}
      
      {image && (
        <div class="mb-8">
          <Image src={image} alt={`${title} preview`} class="max-w-md w-full h-auto rounded-xl shadow-lg border border-slate-100" />
        </div>
      )}
      
      {appsource && (
        <a 
          href={appsource} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-block bg-blue-600 text-white font-medium px-6 py-3 rounded hover:bg-blue-700 transition-colors shadow-sm"
        >
          {t('getOnAppSource') || 'Get it on AppSource'}
        </a>
      )}
    </div>

    <div class="prose prose-slate max-w-none mb-12">
      <slot />
    </div>

    {(repo || email) && (
      <div class={`grid grid-cols-1 ${repo ? 'md:grid-cols-2' : ''} gap-6 mb-12`}>
        {repo && (
          <div class="bg-slate-50 border border-slate-200 p-6 rounded-lg">
            <h3 class="text-lg font-bold text-brand-navy mb-3">{t('documentation') || 'Documentation'}</h3>
            <ul class="space-y-2">
              <li>
                <a href={`${repo}#readme`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                  {t('officialReadme') || 'Read the Documentation'}
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                </a>
              </li>
              <li>
                <a href={`${repo}/blob/main/PRIVACY.md`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                  {t('privacyPolicy') || 'Privacy Policy'}
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                </a>
              </li>
              <li>
                <a href={`${repo}/blob/main/EULA.txt`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                  {t('eula') || 'End User License Agreement'}
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                </a>
              </li>
              <li>
                <a href={`${repo}/blob/main/LICENSE.txt`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                  {t('sourceCodeLicense') || 'Source Code License (MIT)'}
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                </a>
              </li>
            </ul>
          </div>
        )}
        
        <div id="support" class="bg-slate-50 border border-slate-200 p-6 rounded-lg">
          <h3 class="text-lg font-bold text-brand-navy mb-3">{t('support') || 'Support'}</h3>
          <ul class="space-y-2">
            {repo && (
              <>
                <li>
                  <a href={`${repo}/blob/main/SUPPORT.md`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                    {t('supportPolicy') || 'Support Policy'}
                  <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                  </a>
                </li>
                <li>
                  <a href={`${repo}/issues`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                    {t('githubIssues') || 'Report a Bug via GitHub Issues'}
                    <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                  </a>
                </li>
                <li>
                  <a href={`${repo}/discussions`} target="_blank" rel="noopener noreferrer" class="text-brand-cyan hover:text-brand-cyan-dark transition-colors flex items-center gap-1.5 w-fit">
                    {t('githubDiscussions') || 'Ask a question or request a feature via GitHub Discussions'}
                    <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 opacity-80" aria-hidden="true" />
                  </a>
                </li>
              </>
            )}
            {email && (
              <li class="flex items-center gap-1.5">
                <Icon name="heroicons:envelope" class="w-4 h-4 opacity-80 text-brand-cyan" aria-hidden="true" />
                <span class="text-slate-600 text-sm">{t('emailSupport') || 'Email Support'}:</span>
                <a href={`mailto:${email}`} class="text-brand-cyan hover:text-brand-cyan-dark transition-colors">
                  {email}
                </a>
              </li>
            )}
          </ul>
        </div>
      </div>
    )}

    {relatedPosts.length > 0 && (
      <div class="border-t border-slate-200 pt-10">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">{t('relatedArticles')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(post => (
            <BlogCard post={post} lang={lang} />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>