---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n/translations';

export interface Props {
  post: CollectionEntry<'blog'>;
  lang: Locale;
}

const { post, lang } = Astro.props;
const { title, description, published } = post.data;
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="max-w-3xl mx-auto">
    <header class="border-b border-slate-200 pb-8 mb-8">
      <h1 class="text-4xl font-extrabold text-brand-navy mb-2">{title}</h1>
      {description && <p class="text-xl text-brand-muted leading-relaxed mb-6">{description}</p>}

      <time datetime={published.toISOString()} class="text-brand-subtle font-mono text-sm">
        {published.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    
    <div class="prose prose-blue max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>