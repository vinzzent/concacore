---
// src/pages/index.astro

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redirecting...</title>
  
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${base}en-us/`} />
  </noscript>
</head>
<body>
  <p>Redirecting to your preferred language...</p>
  <p><a href={`${base}en-us/`}>Click here if you are not redirected.</a></p>

  <script is:inline define:vars={{ base }}>
    // Define the supported locales strictly in lowercase
    const supportedLocales = ['en-us', 'pt-br'];
    const defaultLocale = 'en-us';

    function getPreferredLanguage() {
      // 1. Capture User Preferences
      const userLangs = navigator.languages || [navigator.language || navigator.userLanguage];

      for (let lang of userLangs) {
        if (!lang) continue;
        
        // Normalize to lower case to ensure routes like /pt-br resolve properly
        const lowerLang = lang.toLowerCase();

        // 2. Perform an Exact Match 
        if (supportedLocales.includes(lowerLang)) {
          return lowerLang;
        }

        // 3. Perform a Partial Match (Fuzzy Matching)
        const baseLang = lowerLang.split('-')[0];
        const match = supportedLocales.find(locale => locale.startsWith(baseLang + '-'));
        
        if (match) {
          return match;
        }
      }
      
      // 5. Fallback Mechanism
      return defaultLocale;
    }

    // Determine target locale
    const targetLocale = getPreferredLanguage();

    // The 'base' variable already guarantees a trailing slash
    const targetUrl = base + targetLocale + '/';

    // 4. Execute the Redirect
    window.location.replace(targetUrl);
  </script>
</body>
</html>