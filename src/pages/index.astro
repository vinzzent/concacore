---
// src/pages/index.astro
// Redireciona a raiz (/) para o idioma padrão (/en-us/)

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="refresh" content={`0;url=${base}en-us/`} />
    <title>Redirecting...</title>
  </head>
  <body>
  </body>
</html>