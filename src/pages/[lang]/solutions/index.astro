---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Locale } from '../../../i18n/translations';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'pt-br' } }
  ];
}

const { lang } = Astro.params as { lang: Locale };

const solutionsPages = await getCollection('solutions', (entry) => {
  return entry.data.lang.toLowerCase() === lang;
});

const doc = solutionsPages[0];

if (!doc) {
  throw new Error(`Solution page not found for this language: ${lang}`);
}

// Astro 6 Loader API requirement
const { Content } = await render(doc);
const { title, subtitle, description } = doc.data;
---

<BaseLayout title={title} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <header class="text-center py-16 border-b border-slate-200 mb-12 animate-fade-up">
      <span class="text-brand-cyan font-bold tracking-wider uppercase text-sm mb-4 block">
        {title}
      </span>
      <h1 class="text-5xl font-extrabold mb-6 text-brand-navy leading-tight">
        {subtitle}
      </h1>
      <p class="text-xl text-brand-muted leading-relaxed max-w-3xl mx-auto">
        {description}
      </p>
    </header>

    <div class="prose prose-lg max-w-none pb-16">
      <Content />
    </div>
  </div>
</BaseLayout>