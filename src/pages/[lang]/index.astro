---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/translations';
import type { Locale } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'pt-br' } }
  ];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
---

<BaseLayout title={t('home')} description={t('defaultDescription')} lang={lang}>
  <section class="text-center py-20">
    <h1 class="text-5xl font-extrabold mb-6">{t('defaultDescription')}</h1>
    <p class="text-xl text-gray-600 mb-8">{t('footerTagline')}</p>
    
    <a href={`/${lang}/blog/`} class="inline-block bg-blue-600 text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-700 transition">
      {t('blog')}
    </a>
  </section>
</BaseLayout>