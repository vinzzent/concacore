---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { useTranslations } from '../../i18n/translations';
import type { Locale } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'pt-br' } }
  ];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

// Fetch products and filter by the current language
const products = await getCollection('products', (entry) => {
  return entry.data.lang.toLowerCase() === lang;
});
---

<BaseLayout title={t('home') || 'Home'} description={t('defaultDescription') || ''} lang={lang}>
  <header class="text-center py-16 border-b border-slate-200 mb-12">
    <h1 class="text-5xl font-extrabold text-brand-navy mb-6 leading-tight">{t('defaultDescription')}</h1>
    <p class="text-xl text-brand-muted leading-relaxed max-w-3xl mx-auto mb-2">{t('footerTagline')}</p>
  </header>
    
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto text-left">
      {products.map((product) => (
        <ProductCard product={product} lang={lang} />
      ))}
  </div>
</BaseLayout>