---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; // 1. Importar o tipo
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getResourcesAsArray } from '../../../data/resources';
import { useTranslations } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export function getStaticPaths() {
  return [{ params: { lang: 'en-us' } }, { params: { lang: 'pt-br' } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

// 2. Tipar rigorosamente a variável rawPosts e o parâmetro entry
const rawPosts: CollectionEntry<'blog'>[] = await getCollection(
  'blog', 
  (entry: CollectionEntry<'blog'>) => entry.data.lang.toLowerCase() === lang
);

const posts = rawPosts.map((post) => {
  // Extract slug from path-based ID (e.g. "en-us/airflow-vs-prefect" -> "airflow-vs-prefect")
  const slug = post.id.split('/').pop(); 
  
  return {
    id: slug as string,
    title: post.data.title,
    description: post.data.description,
    published: post.data.published,
    tag: t('article') || 'Article',
    url: `/${lang}/blog/${slug}/`
  };
});

// 3. Busca os Recursos (Objeto JS)
const rawResources = getResourcesAsArray();

const resources = rawResources.map(res => {
  const localData = res.translations[lang];
  return {
    id: res.id,
    title: localData.title,
    description: localData.description,
    published: localData.published,
    tag: t(res.type as any) || res.type, 
    url: `/${lang}/blog/${res.id}/`
  };
});

// 4. Mescla e Ordena por Data
const feed = [...posts, ...resources].sort((a, b) => b.published.valueOf() - a.published.valueOf());
---

<BaseLayout title={t('blog') || 'Blog'} lang={lang}>
  <h1 class="text-4xl font-bold text-brand-navy mb-8">{t('blog') || 'Blog'}</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {/* Como "feed" é formado por objetos bem definidos lá em cima, "item" já é inferido automaticamente aqui em baixo! */}
    {feed.map(item => (
      <article class="border border-slate-200 bg-white rounded-lg p-6 flex flex-col h-full shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs font-bold text-brand-cyan mb-2 uppercase tracking-wide">{item.tag}</span>
        <h3 class="text-xl font-bold text-brand-navy mb-2 leading-tight">
          <a href={item.url} class="hover:text-brand-cyan transition-colors">{item.title}</a>
        </h3>
        <p class="text-brand-muted mb-4 grow text-sm leading-relaxed">{item.description}</p>
        <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center text-sm">
          <time datetime={item.published.toISOString()} class="text-brand-subtle font-mono text-xs">
            {item.published.toLocaleDateString(lang)}
          </time>
          <a href={item.url} class="font-semibold text-brand-cyan hover:text-brand-cyan-dark flex items-center gap-1 transition-colors">
            {t('viewBtn') || 'View'} &rarr;
          </a>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>