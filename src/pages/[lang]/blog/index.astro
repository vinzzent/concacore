---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getResourcesAsArray } from '../../../data/resources';
import { useTranslations } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export function getStaticPaths() {
  return [{ params: { lang: 'en-us' } }, { params: { lang: 'pt-br' } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

// 1. Busca os Artigos (Markdown)
const rawPosts = await getCollection('blog', (entry: CollectionEntry<'blog'>) => entry.data.lang.toLowerCase() === lang);
const posts = rawPosts.map((post: CollectionEntry<'blog'>) => ({
  id: post.slug,
  title: post.data.title,
  description: post.data.description,
  published: post.data.published,
  tag: t('article'),
  url: `/${lang}/blog/${post.slug}/`
}));

// 2. Busca os Recursos (Objeto JS)
const rawResources = getResourcesAsArray();
const resources = rawResources.map(res => {
  const localData = res.translations[lang];
  return {
    id: res.id,
    title: localData.title,
    description: localData.description,
    published: localData.published,
    tag: t(res.type), // Traduz o tipo do recurso
    url: `/${lang}/blog/${res.id}/`
  };
});

// 3. Mescla e Ordena por Data
const feed = [...posts, ...resources].sort((a, b) => b.published.valueOf() - a.published.valueOf());
---

<BaseLayout title={t('blog')} lang={lang}>
  <h1 class="text-4xl font-bold mb-8">{t('blog')}</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {feed.map(item => (
      <article class="border rounded-lg p-6 flex flex-col h-full shadow-sm hover:shadow-md">
        <span class="text-xs font-bold text-blue-600 mb-2 uppercase">{item.tag}</span>
        <h3 class="text-xl font-bold mb-2">
          <a href={item.url} class="hover:underline">{item.title}</a>
        </h3>
        <p class="text-gray-600 mb-4 flex-grow">{item.description}</p>
        <div class="mt-auto pt-4 border-t flex justify-between items-center text-sm">
          <time datetime={item.published.toISOString()} class="text-gray-500">
            {item.published.toLocaleDateString(lang)}
          </time>
          <a href={item.url} class="font-medium text-blue-600 hover:underline">{t('viewBtn')} &rarr;</a>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>