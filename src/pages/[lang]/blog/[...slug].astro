---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getResourcesAsArray } from '../../../data/resources';
import type { ResourceData } from '../../../data/resources'; // Import the type
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ResourceLayout from '../../../layouts/ResourceLayout.astro';
import type { Locale } from '../../../i18n/translations';

export async function getStaticPaths() {
  const paths = [];

  // 1. Gera caminhos para os Artigos (Markdown)
  const posts = await getCollection('blog');
  
  for (const post of posts) {
    const lang = post.data.lang.toLowerCase() as Locale;
    const slug = post.id.split('/').pop(); 
    
    paths.push({
      params: { lang, slug },
      props: { type: 'post' as const, data: post, lang } 
    });
  }

  // 2. Gera caminhos para os Recursos (JS)
  const resources = getResourcesAsArray();
  for (const resource of resources) {
    for (const lang of ['en-us', 'pt-br'] as Locale[]) {
      paths.push({
        params: { lang, slug: resource.id },
        props: { type: 'resource' as const, data: resource, lang } 
      });
    }
  }

  return paths;
}

// 3. Define the strict union type for props
type Props = 
  | { type: 'post'; data: CollectionEntry<'blog'>; lang: Locale }
  | { type: 'resource'; data: ResourceData; lang: Locale };

const props = Astro.props as Props;

// 4. Safely render conditionally using props.type as the discriminant
let Content;
if (props.type === 'post') {
  const rendered = await render(props.data);
  Content = rendered.Content;
}
---

{props.type === 'post' && Content ? (
  <BlogPostLayout post={props.data} lang={props.lang}>
    <Content />
  </BlogPostLayout>
) : props.type === 'resource' ? (
  <ResourceLayout 
    resource={props.data.translations[props.lang]} 
    format={props.data.format} 
    type={props.data.type}
    lang={props.lang} 
  />
) : null}